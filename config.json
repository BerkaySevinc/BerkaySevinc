{
  "theme": {

    "_gradient_comment": "Two-stop gradient used in header, divider, and footer backgrounds. Must be 6-digit hex values.",
    "gradient": ["#1e1b4b", "#4c1d95"],

    "_accent_comment": "Accent color used for typing text, cursor, and stats values.",
    "accent": "#a78bfa"

  },

  "header": {

    "_generates": "assets/header.svg",
    "_comment": "null = fetch from GitHub API",

    "name": null,
    "bio": null
  },

  "typing": {

    "_generates": "assets/typing.svg",
    "_comment": "null or [] = fetch from GitHub profile (bio, company, location, blog)",

    "lines": [
      ".NET & C# Developer",
      "ASP.NET Core · Node.js",
      "HTML · CSS · JavaScript",
      "AI-Assisted Engineering",
      "Spec-Driven Development"
    ]
  },

  "sections": [

    {
      "_generates": "assets/sections/{id}.svg",
      "_comment": "Each section renders a labeled badge row. Add or remove objects below to manage sections."
    },

    {
      "id": "lang",
      "label": "Languages",
      "badges": [
        { "text": "C#",          "color": "#1d7a1a" },
        { "text": "JAVASCRIPT",  "color": "#e0c910" },
        { "text": "HTML5",       "color": "#cc4420" },
        { "text": "CSS3",        "color": "#1262a0" }
      ]
    },
    {
      "id": "fw",
      "label": "Frameworks & Runtimes",
      "badges": [
        { "text": ".NET",         "color": "#4d2680" },
        { "text": "ASP.NET CORE", "color": "#4422bb" },
        { "text": "NODE.JS",      "color": "#2b802b" }
      ]
    },
    {
      "id": "tools",
      "label": "Tools & Environment",
      "badges": [
        { "text": "GIT",           "color": "#d94229" },
        { "text": "GITHUB",        "color": "#1c2025" },
        { "text": "VISUAL STUDIO", "color": "#4d2680" },
        { "text": "VS CODE",       "color": "#0069b3" },
        { "text": "CLAUDE CODE",   "color": "#bf6a05" }
      ]
    }
  ],

  "divider": {

    "_generates": "assets/divider.svg",
    "_comment": "Thin animated ribbon divider with wavy top and bottom edges — static, no config needed"

  },

  "stats": {

    "_generates": "assets/stats.svg",
    "_comment": "GitHub Stats Card — fetched automatically via GitHub GraphQL API",

    "show": {
      "commits":   true,
      "prs":       false,
      "issues":    false,
      "stars":     true,
      "repos":     true,
      "followers": false
    }

  },

  "langs": {

    "_generates": "assets/langs.svg",
    "_comment": "Top Languages Chart — fetched automatically via GitHub GraphQL API"

  },

  "footer": {

    "_generates": "assets/footer.svg",
    "_comment": "Animated wave footer — static, no config needed"

  }
}
